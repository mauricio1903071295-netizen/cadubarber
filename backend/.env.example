# Porta local do servidor Express (não é usada na Vercel)
PORT=3001

# URL de implantação (deploy) do Google Apps Script Web App (termina em /exec).
# Veja backend/APPS_SCRIPT.md para o código do script e como publicá-lo.
APPS_SCRIPT_URL=https://script.google.com/macros/s/SEU_ID_AQUI/exec

# Token secreto definido na constante API_TOKEN do Apps Script.
APPS_SCRIPT_TOKEN=troque-por-um-segredo-forte

# Senha do painel administrativo (/admin), onde o barbeiro ajusta serviços,
# horário de funcionamento e pode trancar a agenda.
ADMIN_PASSWORD=troque-por-outra-senha-forte

# URL do frontend em produção, para restringir o CORS da API.
# Use "*" (padrão) para liberar geral durante o desenvolvimento.
FRONTEND_URL=*
