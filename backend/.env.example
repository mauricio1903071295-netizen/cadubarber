# Porta local do servidor Express (não é usada na Vercel)
PORT=3001

# E-mail da Service Account criada no Google Cloud Console (veja README)
GOOGLE_CLIENT_EMAIL=cadubarber-agenda@SEU-PROJETO.iam.gserviceaccount.com

# Chave privada da Service Account (campo "private_key" do JSON baixado).
# Mantenha entre aspas e com os "\n" literais, exatamente como está no JSON.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUACHAVEAQUI\n-----END PRIVATE KEY-----\n"

# ID da agenda do Google que será lida/escrita. Normalmente é o e-mail da conta
# dedicada do barbeiro.
GOOGLE_CALENDAR_ID=cadubarber47@gmail.com

# URL do frontend em produção, para restringir o CORS da API.
# Use "*" (padrão) para liberar geral durante o desenvolvimento.
FRONTEND_URL=*
